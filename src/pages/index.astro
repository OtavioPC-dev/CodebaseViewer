---
import GraphView from '../components/GraphView.svelte';

// Fetch the graph for this project's own root at load time (SSR).
const base = new URL(Astro.url.href);
const api = new URL('/api/graph', base);
let graph: any = { nodes: [], edges: [], meta: {} };
let err = '';
try {
  const res = await fetch(api);
  if (!res.ok) throw new Error(`API ${res.status}`);
  graph = await res.json();
} catch (e) {
  err = String(e);
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Codebase Viewer</title>
    <style>
      html, body { margin: 0; height: 100%; background: #0b1020; }
      #app { height: 100vh; }
      .err { color: #f87171; font: 14px system-ui; padding: 20px; }
      .meta { position: absolute; top: 8px; right: 8px; z-index: 2; color: #94a3b8;
              font: 11px system-ui; background: rgba(15,23,42,.8); padding: 6px 10px; border-radius: 8px; }
    </style>
  </head>
  <body>
    <div id="app">
      {err
        ? <div class="err">analysis failed: {err}</div>
        : <>
            <div class="meta">
              {graph.meta.files} files · {graph.meta.defs} defs · {graph.meta.edges} edges ·
              {graph.meta.resolved} resolved calls
            </div>
            <GraphView graph={graph} streamUrl="/api/stream" client:only="svelte" />
          </>}
    </div>
  </body>
</html>
